{
  "ruleSet": {
    "archetype": "B",
    "cap": 3,
    "thresholds": {
      "min_age": 18,
      "high_risk_score": 70,
      "low_loyalty_score": 20
    },
    "rules": [
      {
        "rule_id": "b_underage_guardian",
        "recommendation": "guardian_verification",
        "priority": 100,
        "threshold_refs": ["min_age"],
        "conditions": [{ "field": "age", "op": "lt", "threshold_id": "min_age" }]
      },
      {
        "rule_id": "b_high_risk_review",
        "recommendation": "manual_risk_review",
        "priority": 90,
        "threshold_refs": ["high_risk_score"],
        "conditions": [{ "field": "risk_score", "op": "gte", "threshold_id": "high_risk_score" }]
      },
      {
        "rule_id": "b_low_loyalty_discovery",
        "recommendation": "discovery_offer",
        "priority": 80,
        "threshold_refs": ["low_loyalty_score"],
        "conditions": [{ "field": "loyalty_score", "op": "lt", "threshold_id": "low_loyalty_score" }]
      },
      {
        "rule_id": "b_recent_return_retention",
        "recommendation": "retention_check",
        "priority": 70,
        "conditions": [{ "field": "tags", "op": "contains", "value": "recent_return" }]
      }
    ],
    "fallback": {
      "rule_id": "b_fallback_healthy_discovery",
      "recommendation": "healthy_discovery_loyalty",
      "priority": 10
    }
  },
  "cases": [
    {
      "id": "rank-cap-three",
      "input": {
        "subject": { "age": 16, "risk_score": 91, "loyalty_score": 5, "tags": ["recent_return"] },
        "object": {},
        "ctx": { "question": "Should we renew?" }
      }
    },
    {
      "id": "healthy-fallback-never-empty",
      "input": {
        "subject": { "age": 31, "risk_score": 5, "loyalty_score": 60, "tags": [] },
        "object": {},
        "ctx": { "question": "Give me a promo" }
      }
    }
  ]
}
